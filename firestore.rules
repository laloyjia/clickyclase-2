rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────
    //  Click&Clase — Reglas de seguridad
    //
    //  Roles soportados (en usuarios/{uid}.role):
    //   - 'admin'      → control total
    //   - 'profesor'   → CRUD de sus propios materiales/planificaciones/calendario
    //   - 'estudiante' → solo lectura de materiales/recursos + sus propias evaluaciones
    //
    //  Patrones:
    //   - isOwner(uid)   → request.auth.uid == uid
    //   - isAdmin()      → lee el doc del propio usuario y chequea role == 'admin'
    //   - isProfesor()   → role 'profesor' o 'admin'
    //
    //  Costo: cada chequeo de isAdmin()/isProfesor() cuesta 1 lectura adicional
    //  del doc del propio usuario. Aceptable a la escala actual.
    // ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function _userDocExists() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function _userRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && _userDocExists() && _userRole() == 'admin';
    }
    function isProfesor() {
      return isSignedIn() && _userDocExists() &&
        (_userRole() == 'profesor' || _userRole() == 'admin');
    }
    // Verifica que el doc nuevo/actualizado tenga el uid del autor autenticado
    function authorUidMatches() {
      return isSignedIn() &&
        ('uid' in request.resource.data) &&
        request.resource.data.uid == request.auth.uid;
    }
    // Verifica que el campo `role` no esté siendo modificado en un update
    function roleUnchanged() {
      return !('role' in request.resource.data) ||
        request.resource.data.role == resource.data.role;
    }

    // ── usuarios/{uid} ─────────────────────────────────────────
    // Lectura: el dueño o un admin. Profes pueden leer otros profes
    // (necesario para el dashboard que lista profes en admin).
    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isProfesor();
      // Create:
      //   - admin crea profesores
      //   - self-signup: el propio user crea su perfil inicial
      allow create: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.role in ['estudiante','profesor','admin']);
      // Update:
      //   - admin puede todo
      //   - el dueño puede actualizar pero NO cambiar role, permisos, activo,
      //     formatoPAES, taxonomiaMarzano, liceos, tipoProfesor, tiposProfesor
      //     ni xp/badges (esos los gestiona el sistema)
      allow update: if isAdmin() || (
        isOwner(uid) &&
        roleUnchanged() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role','permisos','activo','formatoPAES','taxonomiaMarzano',
          'tipoProfesor','tiposProfesor','liceos','liceoPrincipal',
          'especialidad','asignaturas','niveles','modulos','cursos'
        ])
      );
      allow delete: if isAdmin();
    }

    // ── materiales (biblioteca compartida) ─────────────────────
    // Lectura: cualquier autenticado (los estudiantes ven materiales).
    // Escritura: solo profe/admin, y solo sobre sus propios docs.
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow create: if isProfesor() && authorUidMatches();
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.uid == request.auth.uid);
    }

    // ── planificaciones (privadas del profe) ───────────────────
    // No las ven estudiantes. Solo dueño y admin.
    match /planificaciones/{planId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isProfesor() && authorUidMatches();
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.uid == request.auth.uid);
    }

    // ── evaluaciones (resultados de estudiantes) ───────────────
    // Lectura: el propio estudiante ve sus resultados. Profe/admin ven todas
    // (para ranking, estadísticas, etc.).
    // Creación: el propio estudiante crea su resultado al terminar evaluación.
    // Edición/borrado: solo admin.
    match /evaluaciones/{evalId} {
      allow read: if isAdmin() || isProfesor() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && authorUidMatches();
      allow update, delete: if isAdmin();
    }

    // ── calendarios_docentes/{uid}/eventos/{evtId} ─────────────
    // Calendario personal del docente. Solo él o admin lo ven/editan.
    match /calendarios_docentes/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── actividad (audit log) ──────────────────────────────────
    // Cualquier autenticado puede CREAR su propio evento (log fire-and-forget).
    // Solo admin lee/purga. No se puede editar (logs inmutables).
    match /actividad/{actId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ── codigos_acceso ─────────────────────────────────────────
    // Lectura puntual permitida (para validar al registrarse).
    // Creación/edición/borrado: solo admin.
    match /codigos_acceso/{codId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── liceos (catálogo institucional) ────────────────────────
    match /liceos/{liceoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── recursos_curricula y curricula ─────────────────────────
    match /recursos_curricula/{recId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /curricula/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── sistema (config IA, API keys Gemini) ───────────────────
    // CRÍTICO: solo admin. Las keys nunca deben salir al cliente.
    // La fuente autoritativa de las keys debe ser env vars del backend
    // (Vercel). Este doc queda como respaldo administrativo.
    match /sistema/{docId} {
      allow read, write: if isAdmin();
    }

    // ── anuncios (comunicados de admin a profesores) ───────────
    // Lectura: cualquier autenticado (los profesores ven los comunicados).
    // Creación/edición/borrado: solo admin.
    match /anuncios/{anuncioId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── listas_curso (nóminas de estudiantes por curso) ────────
    // Cada doc pertenece a un profesor (profesorUid). Lo lee y edita
    // su dueño o un admin.
    match /listas_curso/{listaId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ── notas_curso (libro de calificaciones por curso) ────────
    // Mismo criterio que listas_curso: dueño (profesorUid) o admin.
    match /notas_curso/{notasId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ── asistencia_curso (registro de asistencia diaria) ───────
    // Mismo criterio que listas_curso/notas_curso: dueño o admin.
    match /asistencia_curso/{asisId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ── Default deny: cualquier ruta no listada arriba se bloquea ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
