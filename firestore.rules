rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Reglas temporales de arranque ──────────────────────────
    // Permiten leer/escribir a cualquier usuario autenticado
    // Una vez que todo funcione, reemplaza con las reglas estrictas

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
