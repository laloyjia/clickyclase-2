rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────
    //  Click&Clase — Reglas de seguridad
    //
    //  Roles soportados (en usuarios/{uid}.role):
    //   - 'admin'      → control total
    //   - 'profesor'   → CRUD de sus propios materiales/planificaciones/calendario
    //   - 'estudiante' → solo lectura de materiales/recursos + sus propias evaluaciones
    //
    //  Patrones:
    //   - isOwner(uid)   → request.auth.uid == uid
    //   - isAdmin()      → lee el doc del propio usuario y chequea role == 'admin'
    //   - isProfesor()   → role 'profesor' o 'admin'
    //
    //  Costo: cada chequeo de isAdmin()/isProfesor() cuesta 1 lectura adicional
    //  del doc del propio usuario. Aceptable a la escala actual.
    // ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function _userDocExists() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function _userRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role;
    }
    function _userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && _userDocExists() && _userRole() == 'admin';
    }
    function isProfesor() {
      return isSignedIn() && _userDocExists() &&
        (_userRole() == 'profesor' || _userRole() == 'admin');
    }
    // ── Helpers para roles múltiples (nuevo formato) ─────────────
    // Soporta tanto `role: 'string'` (legacy) como `roles: { <id>: {...} }`.
    function _hasRole(roleId) {
      return isSignedIn() && _userDocExists() && (
        (('role' in _userDoc()) && _userDoc().role == roleId) ||
        (('roles' in _userDoc()) && (roleId in _userDoc().roles))
      );
    }
    function _hasAnyRole(rolesIds) {
      return isSignedIn() && _userDocExists() && (
        (('role' in _userDoc()) && _userDoc().role in rolesIds) ||
        (('roles' in _userDoc()) &&
          _userDoc().roles.keys().hasAny(rolesIds))
      );
    }
    // Liceo del usuario autenticado (para filtros multi-tenant).
    function _userLiceo() {
      return _userDocExists() && ('liceoSlug' in _userDoc()) ? _userDoc().liceoSlug : '';
    }
    // Directivo: director, rector, admin_colegio o UTP.
    function isDirectivo() {
      return _hasAnyRole(['director','rector','admin_colegio','utp']);
    }
    // Encargado de área: encargados de ciclo/TP, además de UTP y directivos.
    function puedeAprobarMaterial() {
      return _hasAnyRole([
        'admin','director','rector','admin_colegio','utp','encargado_area'
      ]);
    }
    // Equipos con acceso a datos sensibles (PIE, apoyo, convivencia).
    function esEquipoApoyo() {
      return _hasAnyRole(['aps_enc','aps_prof']);
    }
    function esEquipoConvivencia() {
      return _hasAnyRole(['amb_enc','amb_prof']);
    }
    function esEquipoPIE() {
      return _hasAnyRole(['pie_enc','pie_edu']);
    }
    function puedeVerDatosSensibles() {
      return isAdmin() || isDirectivo() || esEquipoApoyo() ||
             esEquipoConvivencia() || esEquipoPIE();
    }
    // ¿Mismo liceo que el doc consultado? Para filtros multi-tenant.
    function mismoLiceo() {
      return ('liceoSlug' in resource.data) &&
             resource.data.liceoSlug == _userLiceo();
    }
    function mismoLiceoNuevo() {
      return ('liceoSlug' in request.resource.data) &&
             request.resource.data.liceoSlug == _userLiceo();
    }
    // ── Autor del documento (retro-compatible) ─────────────────
    // Sistema legacy: campo `uid` (autor). Sistema nuevo: `autorUid`.
    // Aceptamos ambos para no romper docs viejos.
    function esAutor() {
      return isSignedIn() && (
        (('uid' in resource.data) && resource.data.uid == request.auth.uid) ||
        (('autorUid' in resource.data) && resource.data.autorUid == request.auth.uid)
      );
    }
    // ── Campos que un revisor puede modificar durante aprobación ──
    // El autor puede modificar todo el contenido; el revisor solo estos:
    function _cambioSoloRevision() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'estado','estadoFecha',
          'revisorUid','revisorEmail','revisorNombre',
          'aprobadoEn','devueltoEn','reenviadoEn',
          'ultimasObservaciones','historial'
        ]);
    }
    // ── Autor puede cambiar de estado solo en transiciones válidas ──
    //   borrador -> enviada (envío)
    //   devuelta -> borrador (retomar)
    //   devuelta -> enviada  (reenvío directo sin retomar; opcional)
    function _transicionAutorValida() {
      return !('estado' in request.resource.data) ||
             (resource.data.estado == 'borrador' && request.resource.data.estado in ['borrador','enviada']) ||
             (resource.data.estado == 'devuelta' && request.resource.data.estado in ['borrador','enviada']) ||
             (resource.data.estado == 'enviada' && request.resource.data.estado == 'enviada') ||
             (!('estado' in resource.data)); // doc legacy sin estado
    }
    // Verifica que el doc nuevo/actualizado tenga el uid del autor autenticado
    function authorUidMatches() {
      return isSignedIn() &&
        ('uid' in request.resource.data) &&
        request.resource.data.uid == request.auth.uid;
    }
    // Verifica que el campo `role` no esté siendo modificado en un update
    function roleUnchanged() {
      return !('role' in request.resource.data) ||
        request.resource.data.role == resource.data.role;
    }

    // ── usuarios/{uid} ─────────────────────────────────────────
    // Lectura: el dueño, admin plataforma, profesor (para dashboards),
    //          o admin_colegio del mismo liceo (para gestionar su personal).
    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isProfesor()
        || (_hasRole('admin_colegio') && mismoLiceo());
      // Create:
      //   - admin plataforma crea cualquier usuario
      //   - self-signup: el propio user crea su perfil inicial (rol limitado)
      //   - admin_colegio crea usuarios de SU liceo (nunca admin plataforma)
      allow create: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.role in ['estudiante','profesor','admin'])
        || (_hasRole('admin_colegio')
            && request.resource.data.liceoSlug == _userLiceo()
            && request.resource.data.role != 'admin');
      // Update:
      //   - admin plataforma puede todo
      //   - el dueño puede actualizar pero NO cambiar role, permisos, activo,
      //     formatoPAES, taxonomiaMarzano, liceos, tipoProfesor, tiposProfesor
      //   - admin_colegio puede editar personal de su liceo pero NO cambiar
      //     liceoSlug (no puede llevárselo) ni ascender a admin plataforma
      allow update: if isAdmin()
        || (
          isOwner(uid) &&
          roleUnchanged() &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role','permisos','activo','formatoPAES','taxonomiaMarzano',
            'tipoProfesor','tiposProfesor','liceos','liceoPrincipal',
            'especialidad','asignaturas','niveles','modulos','cursos'
          ])
        )
        || (
          _hasRole('admin_colegio') && mismoLiceo() &&
          request.resource.data.liceoSlug == resource.data.liceoSlug &&
          request.resource.data.role != 'admin'
        );
      allow delete: if isAdmin() || (_hasRole('admin_colegio') && mismoLiceo());
    }

    // ── materiales (biblioteca compartida + flujo aprobación) ──
    // Lectura: cualquier autenticado (estudiantes ven aprobadas; el
    // autor y revisores ven en cualquier estado).
    // Escritura: autor cuando estado ∈ {borrador, devuelta}; revisor
    // (utp/encargado/director/rector del mismo liceo) puede cambiar
    // solo campos de flujo cuando estado ∈ {enviada, en_revision}.
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow create: if isProfesor() && authorUidMatches();
      allow update: if isAdmin()
        // El autor puede modificar cuando estado ∈ {borrador, devuelta}
        // O si el doc legacy no tiene estado (retrocompat)
        || (esAutor() && _transicionAutorValida() && (
             !('estado' in resource.data) ||
             resource.data.estado in ['borrador','devuelta','enviada']
           ))
        // El revisor puede cambiar SOLO los campos de flujo
        || (puedeAprobarMaterial() && mismoLiceo() && _cambioSoloRevision());
      allow delete: if isAdmin() || esAutor();
    }

    // ── planificaciones (con flujo de aprobación) ──────────────
    // Lectura: autor, revisores del mismo liceo, admin.
    // Escritura: mismo esquema que materiales.
    match /planificaciones/{planId} {
      allow read: if isAdmin()
        || esAutor()
        || (puedeAprobarMaterial() && mismoLiceo());
      allow create: if isProfesor() && authorUidMatches();
      allow update: if isAdmin()
        || (esAutor() && _transicionAutorValida() && (
             !('estado' in resource.data) ||
             resource.data.estado in ['borrador','devuelta','enviada']
           ))
        || (puedeAprobarMaterial() && mismoLiceo() && _cambioSoloRevision());
      allow delete: if isAdmin() || esAutor();
    }

    // ── evaluaciones (dual: resultados estudiantes + docs de evaluación) ──
    // Este esquema soporta 2 usos: docs de resultado de estudiante (legacy)
    // y docs de evaluación creados por profe con flujo de aprobación (nuevo).
    // Lectura: admin, profesor, dueño legacy, revisores del liceo.
    // Escritura: docs de estudiante como antes; docs de profe con flujo.
    match /evaluaciones/{evalId} {
      allow read: if isAdmin() || isProfesor()
        || (isSignedIn() && resource.data.uid == request.auth.uid)
        || (puedeAprobarMaterial() && mismoLiceo());
      allow create: if isSignedIn() && authorUidMatches();
      allow update: if isAdmin()
        || (esAutor() && _transicionAutorValida() && (
             !('estado' in resource.data) ||
             resource.data.estado in ['borrador','devuelta','enviada']
           ))
        || (puedeAprobarMaterial() && mismoLiceo() && _cambioSoloRevision());
      allow delete: if isAdmin() || esAutor();
    }

    // ── calendarios_docentes/{uid}/eventos/{evtId} ─────────────
    // Calendario personal del docente. Solo él o admin lo ven/editan.
    match /calendarios_docentes/{uid}/{document=**} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── actividad (audit log) ──────────────────────────────────
    // Cualquier autenticado puede CREAR su propio evento (log fire-and-forget).
    // Solo admin lee/purga. No se puede editar (logs inmutables).
    match /actividad/{actId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ── codigos_acceso ─────────────────────────────────────────
    // Lectura puntual permitida (para validar al registrarse).
    // Creación/edición/borrado: solo admin.
    match /codigos_acceso/{codId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── liceos (catálogo institucional multi-tenant) ───────────
    //
    // Cada doc representa un colegio contratado. Contiene datos
    // institucionales, plan contratado, admin principal y estado.
    // Fuente de verdad para el aislamiento por liceoSlug.
    //
    //   Lectura:  cualquier autenticado puede LEER liceos (necesario
    //             para el switcher de rol y visualización de nombre/logo).
    //   Escritura: solo admin plataforma crea/elimina. El admin_colegio
    //             puede actualizar su propio doc (para cambiar logo,
    //             colores, datos de contacto — pero NO plan ni límites).
    match /liceos/{liceoId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        // admin_colegio puede editar su propio liceo pero solo campos permitidos
        (_hasRole('admin_colegio') &&
         liceoId == _userLiceo() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'nombre','direccion','telefono','email','sitio',
           'logoUrl','colores','descripcion'
         ]));
      allow delete: if isAdmin();
    }

    // ── planes (catálogo comercial: basic, pro, enterprise) ────
    // Definición formal de los planes contratables. Solo admin edita.
    // Cualquier autenticado los lee (para mostrar en admin colegio) y
    // los usuarios NO autenticados también (para landing pública).
    match /planes/{planId} {
      allow read:  if true;                     // acceso público
      allow write: if isAdmin();
    }

    // ── contactos_leads (formulario 'Solicitar demo' de la landing) ──
    // Cualquier visitante puede crear un lead (form público). Solo admin
    // los lee/gestiona.
    match /contactos_leads/{leadId} {
      allow create: if true;                    // form público
      allow read:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── pagos_liceo (historial de facturación por colegio) ─────
    // Registro de cada pago recibido/pendiente. Solo admin gestiona.
    // El admin_colegio puede leer los pagos de su propio liceo.
    match /pagos_liceo/{pagoId} {
      allow read:   if isAdmin() ||
        (_hasRole('admin_colegio') && resource.data.liceoSlug == _userLiceo());
      allow create, update, delete: if isAdmin();
    }

    // ── recursos_curricula y curricula ─────────────────────────
    match /recursos_curricula/{recId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /curricula/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── sistema (config IA, API keys Gemini) ───────────────────
    // CRÍTICO: solo admin. Las keys nunca deben salir al cliente.
    // La fuente autoritativa de las keys debe ser env vars del backend
    // (Vercel). Este doc queda como respaldo administrativo.
    match /sistema/{docId} {
      allow read, write: if isAdmin();
    }

    // ── anuncios (comunicados de admin a profesores) ───────────
    // Lectura: cualquier autenticado (los profesores ven los comunicados).
    // Creación/edición/borrado: solo admin.
    match /anuncios/{anuncioId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── listas_curso (nóminas de estudiantes por curso) ────────
    // Cada doc pertenece a un profesor (profesorUid). Lo lee y edita
    // su dueño o un admin.
    match /listas_curso/{listaId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ── notas/{notaId} — Fase 2.3 (nueva) ──────────────────────
    // Cada documento es una nota individual (estudiante + asignatura + concepto).
    //   Lectura:  docente que la registró, docentes del mismo liceo con
    //             asignatura en el curso, directivos/UTP del liceo, admin.
    //   Escritura: solo el docente que la registró, o admin.
    //   El jefe de curso ve todas las notas de su curso (para promedio).
    match /notas/{notaId} {
      allow read: if isAdmin() ||
        (isSignedIn() && mismoLiceo() && (
          resource.data.docenteUid == request.auth.uid ||
          isDirectivo() ||
          _hasAnyRole(['profesor','jefe_curso','encargado_area','pie_edu','pie_enc'])
        ));
      allow create: if isSignedIn() && mismoLiceoNuevo() &&
        request.resource.data.docenteUid == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && mismoLiceo() &&
         resource.data.docenteUid == request.auth.uid);
      allow delete: if isAdmin() ||
        (isSignedIn() && mismoLiceo() &&
         resource.data.docenteUid == request.auth.uid);
    }

    // ── notas_curso (libro de calificaciones por curso) ────────
    // Mismo criterio que listas_curso: dueño (profesorUid) o admin.
    match /notas_curso/{notasId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ── asistencia_curso (registro de asistencia diaria) ───────
    // Mismo criterio que listas_curso/notas_curso: dueño o admin.
    match /asistencia_curso/{asisId} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.profesorUid == request.auth.uid);
      allow create: if isAdmin() ||
        (isProfesor() && request.resource.data.profesorUid == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isProfesor() && resource.data.profesorUid == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════
    //  COLECCIONES FASE 0/1 — Roles múltiples + multi-tenant + aprobación
    // ═══════════════════════════════════════════════════════════════

    // ── cursos/{cursoId} ──────────────────────────────────────────
    // Un curso pertenece a un liceo. Contiene roster de estudiantes,
    // jefe de curso, asignaturas asignadas.
    //   Lectura:  cualquier usuario del mismo liceo.
    //   Escritura: admin plataforma, directivos del liceo, o jefe de curso.
    match /cursos/{cursoId} {
      allow read:   if isAdmin() || (isSignedIn() && mismoLiceo());
      allow create: if (isAdmin() || isDirectivo()) && mismoLiceoNuevo();
      allow update: if isAdmin() ||
        (isDirectivo() && mismoLiceo()) ||
        (isSignedIn() && mismoLiceo() &&
         'jefeUid' in resource.data && resource.data.jefeUid == request.auth.uid);
      allow delete: if isAdmin() || (isDirectivo() && mismoLiceo());
    }

    // ── libro_clases/{regId} ──────────────────────────────────────
    // Registro diario: asistencia + contenido + observaciones + firma.
    //   Lectura:  autor, jefe de curso, directivos y UTP del mismo liceo.
    //   Escritura: solo el autor (docente que hizo la clase).
    match /libro_clases/{regId} {
      allow read: if isAdmin() ||
        (isSignedIn() && mismoLiceo() && (
          resource.data.docenteUid == request.auth.uid ||
          isDirectivo() ||
          _hasAnyRole(['encargado_area','jefe_curso'])
        ));
      allow create: if isSignedIn() && mismoLiceoNuevo() &&
        request.resource.data.docenteUid == request.auth.uid;
      allow update: if isSignedIn() && mismoLiceo() &&
        resource.data.docenteUid == request.auth.uid &&
        // No permitir reeditar después de firmado
        (!('firmado' in resource.data) || !resource.data.firmado);
      allow delete: if isAdmin();
    }

    // ── intervenciones_apoyo/{id} ─────────────────────────────────
    // Datos sensibles. Solo equipo apoyo psicosocial, directivos y admin.
    match /intervenciones_apoyo/{intId} {
      allow read:   if isAdmin() ||
        (mismoLiceo() && (esEquipoApoyo() || isDirectivo()));
      allow create: if isAdmin() ||
        (mismoLiceoNuevo() && esEquipoApoyo() &&
         request.resource.data.profesionalUid == request.auth.uid);
      allow update: if isAdmin() ||
        (mismoLiceo() && esEquipoApoyo() &&
         resource.data.profesionalUid == request.auth.uid);
      allow delete: if isAdmin() ||
        (mismoLiceo() && _hasRole('aps_enc'));
    }

    // ── entrevistas_convivencia/{id} ──────────────────────────────
    // Registro de entrevistas con apoderados y alumnos. Datos sensibles.
    match /entrevistas_convivencia/{entId} {
      allow read:   if isAdmin() ||
        (mismoLiceo() && (esEquipoConvivencia() || isDirectivo()));
      allow create: if isAdmin() ||
        (mismoLiceoNuevo() && esEquipoConvivencia() &&
         request.resource.data.profesionalUid == request.auth.uid);
      allow update: if isAdmin() ||
        (mismoLiceo() && esEquipoConvivencia() &&
         resource.data.profesionalUid == request.auth.uid);
      allow delete: if isAdmin() ||
        (mismoLiceo() && _hasRole('amb_enc'));
    }

    // ── pie_estudiantes/{estUid} ──────────────────────────────────
    // Ficha PIE por estudiante: diagnóstico, decreto, adecuaciones.
    // Datos altamente sensibles: solo equipo PIE, directivos y admin.
    match /pie_estudiantes/{estUid} {
      allow read:   if isAdmin() ||
        (mismoLiceo() && (esEquipoPIE() || isDirectivo() ||
          // Jefe del curso del estudiante también puede ver (para adecuaciones)
          _hasRole('jefe_curso')));
      allow create, update: if isAdmin() ||
        (mismoLiceoNuevo() && esEquipoPIE());
      allow delete: if isAdmin() ||
        (mismoLiceo() && _hasRole('pie_enc'));
    }

    // ── Default deny: cualquier ruta no listada arriba se bloquea ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
